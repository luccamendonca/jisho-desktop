{
  "name": "jisho",
  "version": "1.0.4",
  "description": "Native-ish macOS wrapper for Jisho.org",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "release": "electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": {
    "name": "Lucca Mendonça",
    "email": "lucca.mendonca@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "org.jisho.app",
    "productName": "Jisho",
    "publish": "github",
    "mac": {
      "icon": "image/icon.icns",
      "category": "public.app-category.reference",
      "darkModeSupport": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Jisho"
    },
    "win": {
      "icon": "image/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "linux": {
      "icon": "image/icon.png",
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Education"
    }
  }
}
